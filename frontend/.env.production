# Production build defaults (Cloudflare Pages, npm run build).
# Sized to Gemini's retry envelope — matches production nginx proxy_read_timeout (90s).
# Local Docker Compose overrides to 600000 via docker-compose.override.yml build args.
VITE_CHAT_REQUEST_TIMEOUT_MS=90000

# Hide SourceList in production — inline job hyperlinks (ADR-0009) already surface links
# in the answer. Local npm run dev / Docker Compose keep the default (true) via unset
# or docker-compose.override.yml build args. Do not gate on import.meta.env.PROD.
VITE_SHOW_SOURCES=false

# Production-appropriate loading copy (Gemini is seconds, not minutes).
# Local Ollama-aware default is used when unset (npm run dev / Compose override).
VITE_LOADING_MESSAGE=Searching and thinking — this can take a few moments, thanks for your patience.
