# Browser-reachable API URL (not a Docker-internal hostname).
# The browser runs on the host and must reach the API via a published port.
# Same-origin /api proxy in Vite dev and Docker nginx (see vite.config.ts).
VITE_API_BASE_URL=/api

# Show SourceList under assistant replies (compact or debug chips).
# Default true when unset — useful for local retrieval debugging.
# Production builds set false in .env.production (inline hyperlinks suffice).
# Do not infer from import.meta.env.PROD / DEV (Compose builds a production bundle locally).
# VITE_SHOW_SOURCES=true

# Full-size sources list with similarity scores (ADR-0009 Decision 5).
# Only relevant when VITE_SHOW_SOURCES is true (or unset).
# Default false — compact source chips in the chat UI. Set true only when
# debugging retrieval quality or link-fidelity locally.
VITE_SHOW_DEBUG_SOURCES=false

# Loading indicator copy under the chat while /chat is in flight.
# Default (when unset): "Searching jobs and generating an answer… Local models may take a few minutes."
# Production builds override in .env.production. Do not gate on import.meta.env.PROD / DEV.
# VITE_LOADING_MESSAGE=Searching jobs and generating an answer… Local models may take a few minutes.

# Browser-side /chat fetch timeout in milliseconds (AbortController).
# Local dev / Ollama: 600000 (10 min). Production builds use .env.production (90000).
# VITE_CHAT_REQUEST_TIMEOUT_MS=600000

# Max characters accepted in the chat textarea (HTML maxLength + live counter).
# Default 500 — must stay in sync with backend CHAT_QUESTION_MAX_LENGTH
# (db/settings.py / ADR-0006). Tuning one without the other will cause a
# client hard-stop that disagrees with the API's 422 string_too_long check.
# VITE_CHAT_QUESTION_MAX_LENGTH=500
