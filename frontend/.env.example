# Browser-reachable API URL (not a Docker-internal hostname).
# The browser runs on the host and must reach the API via a published port.
# Same-origin /api proxy in Vite dev and Docker nginx (see vite.config.ts).
VITE_API_BASE_URL=/api

# Full-size sources list with similarity scores (ADR-0009 Decision 5).
# Default false — compact source chips in the chat UI. Set true only when
# debugging retrieval quality or link-fidelity locally.
VITE_SHOW_DEBUG_SOURCES=false

# Browser-side /chat fetch timeout in milliseconds (AbortController).
# Local dev / Ollama: 600000 (10 min). Production builds use .env.production (90000).
# VITE_CHAT_REQUEST_TIMEOUT_MS=600000
