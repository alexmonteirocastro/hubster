QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=JOBS_ON_THE_HUB
QDRANT_DEV_COLLECTION_NAME=JOBS_DEV
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Comma-separated browser origins allowed to call the API (CORS). Defaults to the Vite dev server.
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# Browser-reachable API URL for the frontend Docker build (not a Docker-internal hostname).
# Use /api when serving via the frontend nginx proxy (default in docker compose).
# VITE_API_BASE_URL=/api

# Gemini generation (required for /chat when LLM_PROVIDER=gemini, the default)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MAX_RETRIES=3
# GEMINI_BACKOFF_FACTOR=1.0
# GEMINI_TIMEOUT=30.0

# Instant stub answers for UI testing (no Gemini quota, no Ollama latency)
# LLM_PROVIDER=stub

# Local Ollama generation (set LLM_PROVIDER=ollama; GEMINI_API_KEY not required)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# Docker Compose + Ollama on the host (macOS/Windows Docker Desktop):
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
# OLLAMA_MODEL=qwen3:4b
# OLLAMA_TIMEOUT_SECONDS=120.0
# CPU inference: default 60s may 502 with limit=5 context — try 180–300 or lower /chat limit
# OLLAMA_MAX_CHARS_PER_JOB=1200
# OLLAMA_NUM_PREDICT=256

# POST /chat hardening (defaults shown)
# CHAT_QUESTION_MAX_LENGTH=500
# CHAT_RATE_LIMIT=10/minute
# CHAT_SOURCE_MIN_SCORE=0.70

# Optional: outbound Hub API client (defaults shown)
# HUB_CLIENT_MAX_RETRIES=3
# HUB_CLIENT_BACKOFF_FACTOR=1.0
# HUB_CLIENT_REQUEST_DELAY=0.25
# HUB_CLIENT_TIMEOUT=30.0
